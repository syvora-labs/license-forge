# ── License Forge — Environment Variables ─────────────────────────────────────
# Copy to .env at the repo root, then fill in the values.
# For local dev:  docker compose up  → Supabase runs at http://localhost:8000
# For production: same stack, different URLs and real secrets.
# NEVER commit .env — it is listed in .gitignore.

# ── Secrets ────────────────────────────────────────────────────────────────────
# Generate JWT_SECRET:          openssl rand -base64 32
# Generate ANON_KEY / SERVICE_ROLE_KEY:
#   https://supabase.com/docs/guides/self-hosting#api-keys
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlhdCI6MTY0MDk5NTIwMCwiZXhwIjoxOTU2NTcxMjAwfQ.dc_X5iR_VP_qroESuzU1O8pfPHLMGkZgXdtFzAOfv8A
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoic2VydmljZV9yb2xlIiwiaWF0IjoxNjQwOTk1MjAwLCJleHAiOjE5NTY1NzEyMDB9.EGIM96RAZx35lJzdJsyH-qQwv8Hj04zWl196z2-SBc0

# ── Database ───────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# ── URLs ───────────────────────────────────────────────────────────────────────
# Local:      http://localhost:8000  /  http://localhost:3000
# Production: https://supabase.your-domain.com  /  https://your-domain.com
SITE_URL=http://localhost:3000
API_EXTERNAL_URL=http://localhost:8000
SUPABASE_PUBLIC_URL=http://localhost:8000

# ── Frontend (Vite) ────────────────────────────────────────────────────────────
# These mirror the values above — point at the self-hosted Kong gateway.
VITE_SUPABASE_URL=http://localhost:8000
VITE_SUPABASE_ANON_KEY=${ANON_KEY}
# Service role key bypasses RLS — only used by admin pages, keep it secret.
VITE_SUPABASE_SERVICE_ROLE_KEY=${SERVICE_ROLE_KEY}

# ── Auth ───────────────────────────────────────────────────────────────────────
DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true
JWT_EXPIRY=3600
ADDITIONAL_REDIRECT_URLS=

# ── Studio dashboard ───────────────────────────────────────────────────────────
STUDIO_DEFAULT_ORGANIZATION=License Forge
STUDIO_DEFAULT_PROJECT=license-forge
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=this_password_is_insecure_and_should_be_updated

# ── Edge functions ─────────────────────────────────────────────────────────────
FUNCTIONS_VERIFY_JWT=false
